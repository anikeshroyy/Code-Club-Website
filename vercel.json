{
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(facebookexternalhit|twitterbot|slackbot|vkShare|W3C_Validator|redditbot|applebot|WhatsApp|SkypeUriPreview|discordbot|linkedinbot|embedly).*"
        }
      ],
      "destination": "/api/seo"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
